{
  "name": "taskflow",
  "version": "1.0.0",
  "description": "TaskFlow — multi-tenant task management SaaS",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "test": "cross-env NODE_ENV=test jest --forceExit",
    "test:verbose": "cross-env NODE_ENV=test jest --forceExit --verbose",
    "migrate": "knex migrate:latest",
    "migrate:prod": "cross-env NODE_ENV=production knex migrate:latest",
    "migrate:test": "cross-env NODE_ENV=test knex migrate:latest",
    "seed": "knex seed:run",
    "rollback": "knex migrate:rollback --all"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.12.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000
  }
}
