# PostgreSQL
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=changeme_local_only
POSTGRES_DB=taskflow_dev

# App
NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://taskflow:changeme_local_only@localhost:5432/taskflow_dev
DATABASE_URL_TEST=postgres://taskflow:changeme_local_only@localhost:5432/taskflow_test
API_BASE_URL=http://localhost:4000

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_string_never_commit_the_real_value
BCRYPT_ROUNDS=12

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info

# ── Render deployment ──────────────────────────────────────────────────────────
# DATABASE_URL is provided automatically by Render when you link your PostgreSQL
# service. Copy the "Internal Database URL" from the Render dashboard.
# All other secrets (JWT_SECRET, etc.) must be set manually in:
#   Render Dashboard → your web service → Environment tab
